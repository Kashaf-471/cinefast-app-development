<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar with app name and 3-dot menu -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cinefast"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp" />

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Menu" />
    </RelativeLayout>

    <TextView
        android:id="@+id/selectDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_date"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"/>

    <RadioGroup
        android:id="@+id/dateToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp">

        <RadioButton
            android:id="@+id/today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/today"
            android:background="@drawable/radio_button_background"
            android:textColor="@android:color/white"
            android:button="@null"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:drawableLeft="@android:drawable/ic_menu_today"
            android:drawablePadding="8dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/tomorrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tomorrow"
            android:background="@drawable/radio_button_background"
            android:drawableLeft="@android:drawable/ic_menu_today"
            android:textColor="@android:color/white"
            android:button="@null"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:drawablePadding="8dp"
            android:layout_marginStart="16dp"/>
    </RadioGroup>

    <!-- TabLayout for Now Showing / Coming Soon -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#000000"
        app:tabIndicatorColor="#FF0000"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#888888"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <!-- ViewPager2 for tab content -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
