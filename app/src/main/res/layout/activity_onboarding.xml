            android:orientation="horizontal">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:layout_margin="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/dark_knight"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:layout_margin="6dp"
