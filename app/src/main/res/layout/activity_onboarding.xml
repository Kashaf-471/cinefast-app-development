                android:src="@drawable/inception"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:layout_margin="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/interstellar"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:layout_margin="6dp"
